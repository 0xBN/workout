{
  "meta": {
    "version": "2.0",
    "deload_rule": "first_week_of_month",
    "deload_weight_multiplier": 0.5,
    "note": "Comeback program. Priority: mobility, climbing, longevity. Finger injury recovery."
  },

  "daily": ["core_warmup", "finger_prehab"],

  "weekly": {
    "monday": ["easy_bouldering", "post_stretch_climb"],
    "tuesday": ["lift_lower_pull", "post_stretch_lift"],
    "wednesday": ["climbing_wed", "post_stretch_climb"],
    "thursday": ["mobility_recovery"],
    "friday": ["easy_bouldering", "post_stretch_climb"],
    "saturday": ["lift_upper_hinge", "thoracic_rotation", "post_stretch_lift"],
    "sunday": ["zone2_recovery", "post_stretch_climb"]
  },

  "blocks": {
    "core_warmup": {
      "name": "Core / PT Warmup",
      "type": "flow",
      "flow_label": "Core & PT warmup",
      "flow_sub": "bird dog · dead bug · clamshell · glute bridge · step-down · side plank · copenhagen · band extensors",
      "exercises": [
        {
          "id": "cw1",
          "name": "Bird dog",
          "sets": 2,
          "reps": 10,
          "note": "per side"
        },
        { "id": "cw2", "name": "Dead bug", "sets": 2, "reps": 10 },
        {
          "id": "cw3",
          "name": "Clamshell",
          "sets": 2,
          "reps": 15,
          "note": "per side"
        },
        { "id": "cw4", "name": "Glute bridge", "sets": 2, "reps": 15 },
        {
          "id": "cw5",
          "name": "Eccentric step-down",
          "sets": 3,
          "reps": 10,
          "note": "per side, 3-4s descent"
        },
        {
          "id": "cw6",
          "name": "Side plank",
          "sets": 2,
          "duration": 30,
          "note": "per side"
        },
        {
          "id": "cw7",
          "name": "Copenhagen plank",
          "sets": 2,
          "duration": 20,
          "note": "per side — top leg on bench or chair"
        },
        {
          "id": "cw8",
          "name": "Band extensors",
          "sets": 2,
          "reps": 15,
          "note": "per hand — gym only, skip at home"
        }
      ]
    },

    "finger_prehab": {
      "name": "Abrahangs",
      "type": "flow",
      "flow_label": "Abrahangs",
      "flow_sub": "~10 min · 40% effort · feet on floor · 6hr min between sessions",
      "twice_daily": true,
      "note": "~40% effort, feet on floor. Light strain on forearms only.",
      "exercises": [
        {
          "id": "fp1",
          "name": "4-finger half crimp",
          "duration": 10,
          "rest": 20,
          "sets": 6
        },
        {
          "id": "fp2",
          "name": "3-finger drag",
          "duration": 10,
          "rest": 20,
          "sets": 6
        },
        {
          "id": "fp3",
          "name": "Front-2 open (idx/mid)",
          "duration": 10,
          "rest": 20,
          "sets": 2
        },
        {
          "id": "fp4",
          "name": "Middle-2 open (mid/ring)",
          "duration": 10,
          "rest": 20,
          "sets": 2
        },
        {
          "id": "fp5",
          "name": "Front-2 half crimp (idx/mid)",
          "duration": 10,
          "rest": 20,
          "sets": 2
        },
        {
          "id": "fp6",
          "name": "Middle-2 half crimp (mid/ring)",
          "duration": 10,
          "rest": 20,
          "sets": 2
        }
      ]
    },

    "easy_bouldering": {
      "name": "Bouldering",
      "type": "flow",
      "flow_label": "Easy bouldering",
      "flow_sub": "no limit attempts · stay below threshold · no crimpy holds",
      "exercises": [{ "id": "eb1", "name": "Easy bouldering", "reps": "open" }]
    },

    "climbing_wed": {
      "name": "Wed — 4×4 or Speed",
      "type": "flow",
      "flow_label": "Norwegian 4×4 or Speed climbing",
      "flow_sub": "pick one — tap when done",
      "exercises": [
        {
          "id": "w4a",
          "name": "Speed climbing",
          "reps": "10× speed wall — HR to 4×4 zone"
        },
        { "id": "w4b", "name": "Norwegian 4×4", "reps": "15× continuous V3" }
      ]
    },

    "lift_lower_pull": {
      "name": "Lift — Lower + Pull",
      "type": "checklist",
      "exercises": [
        {
          "id": "ll0",
          "name": "Assisted pistol squat",
          "sets": 3,
          "reps": 5,
          "note": "per side",
          "prescribed_weight": 0
        },
        {
          "id": "ll1",
          "name": "Bulgarian split squat",
          "sets": 3,
          "reps": 8,
          "note": "per leg",
          "weighted": true,
          "working_weight": 60,
          "progression": [0.75, 0.875, 1.0],
          "warmup_weight": 25
        },
        {
          "id": "ll2",
          "name": "Romanian deadlift",
          "sets": 3,
          "reps": 5,
          "weighted": true,
          "working_weight": 145,
          "progression": [0.6, 0.8, 1.0],
          "warmup_weight": 60
        },
        {
          "id": "ll5",
          "name": "Slider hamstring curl",
          "sets": 3,
          "reps": 8,
          "note": "socks on floor, slow eccentric 3-4s"
        },
        {
          "id": "ll3",
          "name": "Weighted pull-ups",
          "sets": 3,
          "reps": 5,
          "weighted": true,
          "working_weight": 55,
          "progression": [0.7, 0.85, 1.0],
          "warmup_weight": 0,
          "note": "added weight lb"
        },
        {
          "id": "ll6",
          "name": "Dumbbell row",
          "sets": 3,
          "reps": 8,
          "note": "per side",
          "weighted": true,
          "working_weight": 45,
          "progression": [0.75, 0.875, 1.0],
          "warmup_weight": 20
        }
      ]
    },

    "lift_upper_hinge": {
      "name": "Lift — Upper + Hinge",
      "type": "checklist",
      "exercises": [
        {
          "id": "lu0",
          "name": "Assisted pistol squat",
          "sets": 3,
          "reps": 5,
          "note": "per side",
          "prescribed_weight": 0
        },
        {
          "id": "lu1",
          "name": "Dumbbell bench press",
          "sets": 3,
          "reps": 8,
          "weighted": true,
          "working_weight": 90,
          "progression": [0.75, 0.875, 1.0],
          "warmup_weight": 35
        },
        {
          "id": "lu2",
          "name": "Overhead press (alt: incline)",
          "sets": 3,
          "reps": 5,
          "weighted": true,
          "working_weight": 65,
          "progression": [0.75, 0.875, 1.0],
          "warmup_weight": 25
        },
        {
          "id": "lu3",
          "name": "Hip thrust",
          "sets": 3,
          "reps": 8,
          "weighted": true,
          "working_weight": 95,
          "progression": [0.6, 0.8, 1.0],
          "warmup_weight": 40
        },
        {
          "id": "lu4",
          "name": "Suitcase hold",
          "sets": 3,
          "duration": 45,
          "note": "per side",
          "weighted": true,
          "working_weight": 45,
          "progression": [0.75, 0.875, 1.0],
          "warmup_weight": 20
        }
      ]
    },

    "thoracic_rotation": {
      "name": "Thoracic Mobility",
      "type": "flow",
      "flow_label": "Thoracic rotation",
      "flow_sub": "cat-cow · thread the needle · 2 min",
      "exercises": [
        { "id": "tr1", "name": "Thoracic rotation", "reps": "2 min" }
      ]
    },

    "mobility_recovery": {
      "name": "Thursday Mobility",
      "type": "checklist",
      "exercises": [
        {
          "id": "th1",
          "name": "QL foam roll",
          "sets": 1,
          "duration": 180,
          "note": "left side focus — lateral to spine between last rib and hip"
        },
        {
          "id": "th2",
          "name": "McGill side bridge",
          "sets": 3,
          "duration": 30,
          "note": "RIGHT side only — scoliosis correction"
        },
        { "id": "th3", "name": "Cat-cow", "sets": 1, "reps": 10 },
        {
          "id": "th4",
          "name": "Thread the needle",
          "sets": 2,
          "reps": 8,
          "note": "per side"
        },
        {
          "id": "th5",
          "name": "90/90 hip stretch",
          "sets": 2,
          "duration": 45,
          "note": "per side"
        },
        {
          "id": "th6",
          "name": "Couch stretch",
          "sets": 2,
          "duration": 45,
          "note": "per side — hip flexor"
        },
        {
          "id": "th7",
          "name": "Standing QL stretch",
          "sets": 2,
          "duration": 30,
          "note": "left side — arm overhead, lean right"
        },
        {
          "id": "th8",
          "name": "Doorway chest stretch",
          "sets": 2,
          "duration": 30
        },
        {
          "id": "th9",
          "name": "Wrist extensor stretch",
          "sets": 2,
          "duration": 30,
          "note": "per side"
        }
      ]
    },

    "post_stretch_climb": {
      "name": "Post-Session Stretch",
      "type": "flow",
      "flow_label": "Post-session stretch",
      "flow_sub": "chest · shoulders · wrists · hip flexors · QL",
      "exercises": [
        { "id": "psc1", "name": "Chest opener", "duration": 30 },
        {
          "id": "psc2",
          "name": "Shoulder cross stretch",
          "duration": 30,
          "note": "per side"
        },
        {
          "id": "psc3",
          "name": "Wrist extensor stretch",
          "duration": 30,
          "note": "per side"
        },
        {
          "id": "psc4",
          "name": "Couch stretch",
          "duration": 45,
          "note": "per side"
        },
        {
          "id": "psc5",
          "name": "Standing QL stretch",
          "duration": 30,
          "note": "left side — arm overhead lean right"
        }
      ]
    },

    "post_stretch_lift": {
      "name": "Post-Session Stretch",
      "type": "flow",
      "flow_label": "Post-session stretch",
      "flow_sub": "hamstrings · hip flexors · QL · chest · wrists",
      "exercises": [
        {
          "id": "psl1",
          "name": "Standing hamstring stretch",
          "duration": 40,
          "note": "per side"
        },
        {
          "id": "psl2",
          "name": "Couch stretch",
          "duration": 45,
          "note": "per side"
        },
        {
          "id": "psl3",
          "name": "Standing QL stretch",
          "duration": 30,
          "note": "left side — arm overhead lean right"
        },
        { "id": "psl4", "name": "Chest opener", "duration": 30 },
        {
          "id": "psl5",
          "name": "Wrist extensor stretch",
          "duration": 30,
          "note": "per side"
        }
      ]
    },

    "zone2_recovery": {
      "name": "Zone 2 / Recovery",
      "type": "flow",
      "flow_label": "Zone 2 / Recovery",
      "flow_sub": "pick one: 40 min bike · row · hike · easy climbing · full rest",
      "exercises": [
        { "id": "z1", "name": "Zone 2 cardio", "reps": "40 min bike/row/hike" },
        { "id": "z2", "name": "Easy climbing", "reps": "V1–V3 only" },
        { "id": "z3", "name": "Full rest", "reps": "—" }
      ]
    },

    "_paused_limit_bouldering": {
      "name": "Limit Bouldering",
      "type": "checklist",
      "note": "PAUSED — finger injury",
      "exercises": [
        { "id": "lb1", "name": "Warm-up problems", "reps": "5 problems V1→V4" },
        {
          "id": "lb2",
          "name": "Hard problems (V7)",
          "reps": "6 problems, max 10 tries"
        }
      ]
    },

    "_paused_max_hangs": {
      "name": "Max Hangs",
      "type": "checklist",
      "note": "PAUSED — finger injury",
      "exercises": [
        {
          "id": "mh1",
          "name": "20mm edge hang",
          "sets": 5,
          "duration": 7,
          "rest": 180,
          "weighted": true
        }
      ]
    },

    "_paused_hangboard": {
      "name": "Hangboard",
      "type": "checklist",
      "note": "PAUSED — finger injury",
      "exercises": [
        {
          "id": "hb1",
          "name": "Half crimp",
          "sets": 3,
          "duration": 10,
          "rest": 120,
          "weighted": true
        },
        {
          "id": "hb2",
          "name": "3-finger drag",
          "sets": 3,
          "duration": 10,
          "rest": 120,
          "weighted": true
        }
      ]
    }
  }
}
