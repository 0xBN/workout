{
  "meta": {
    "version": "2.0",
    "deload_rule": "first_week_of_month",
    "deload_weight_multiplier": 0.5,
    "note": "Comeback program. Priority: mobility, climbing, longevity. Finger injury recovery."
  },
  "daily": ["core_warmup", "finger_prehab"],
  "weekly": {
    "monday": ["easy_bouldering", "post_stretch_climb"],
    "tuesday": ["lift_lower_pull", "post_stretch_lift"],
    "wednesday": ["climbing_wed", "post_stretch_climb"],
    "thursday": ["mobility_recovery"],
    "friday": ["easy_bouldering", "post_stretch_climb"],
    "saturday": ["lift_upper_hinge", "thoracic_rotation", "post_stretch_lift"],
    "sunday": ["zone2_recovery", "post_stretch_climb"]
  },
  "blocks": {
