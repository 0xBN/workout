            "type": "prepare",
            "label": "Bird dog. Hands and knees. Extend right arm and left leg",
            "duration": 6,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Bird dog \u2014 right arm, left leg",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch. Left arm, right leg",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Bird dog \u2014 left arm, right leg",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Rest",
            "duration": 10
          },
          {
            "type": "prepare",
            "label": "Dead bug. On your back, arms up. Lower right arm and left leg",
            "duration": 7,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Dead bug \u2014 right arm, left leg",
            "duration": 20,
            "countdown_last": 20
