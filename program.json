      "name": "Core / PT Warmup",
      "type": "flow",
      "flow_label": "Core & PT warmup",
      "flow_sub": "bird dog \u00b7 dead bug \u00b7 clamshell \u00b7 glute bridge \u00b7 step-down \u00b7 side plank \u00b7 copenhagen \u00b7 band extensors",
      "exercises": [
        {
          "id": "cw1",
          "name": "Bird dog",
          "sets": 2,
          "reps": 10,
          "note": "per side"
        },
        {
          "id": "cw2",
          "name": "Dead bug",
          "sets": 2,
          "reps": 10
        },
        {
          "id": "cw3",
          "name": "Clamshell",
          "sets": 2,
          "reps": 15,
          "note": "per side"
        },
        {
          "id": "cw4",
          "name": "Glute bridge",
          "sets": 2,
          "reps": 15
