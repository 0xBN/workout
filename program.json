            "duration": 7,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Clamshell \u2014 right side",
            "duration": 25,
            "countdown_last": 25
          },
          {
            "type": "rest",
            "label": "Switch to left side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Clamshell \u2014 left side",
            "duration": 25,
            "countdown_last": 25
