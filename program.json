          {
            "type": "rest",
            "label": "Switch to left foot",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Step-down \u2014 left foot",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Switch to right foot",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Step-down \u2014 right foot",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Switch to left foot",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Step-down \u2014 left foot",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Rest",
            "duration": 10
          },
          {
            "type": "prepare",
            "label": "Side plank. On your right forearm. Hold body straight",
            "duration": 7,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Side plank \u2014 right side",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Switch to left side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Side plank \u2014 left side",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Switch to right side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Side plank \u2014 right side",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Switch to left side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Side plank \u2014 left side",
            "duration": 30,
            "countdown_last": 30
          },
          {
            "type": "rest",
            "label": "Rest",
            "duration": 10
          },
          {
            "type": "prepare",
            "label": "Copenhagen plank. Side plank with top foot on a chair. Hold straight",
            "duration": 7,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Copenhagen \u2014 right side",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch to left side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Copenhagen \u2014 left side",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch to right side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Copenhagen \u2014 right side",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch to left side",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Copenhagen \u2014 left side",
            "duration": 20,
            "countdown_last": 20
          }
        ]
      }
    },
