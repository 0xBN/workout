          {
            "type": "rest",
            "label": "Rest",
            "duration": 10
          },
          {
            "type": "prepare",
            "label": "Eccentric step-down. Stand on right foot. Slowly lower left foot, 3 to 4 seconds",
            "duration": 8,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Step-down \u2014 right foot",
            "duration": 30,
            "countdown_last": 30
