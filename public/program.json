{
  "meta": {
    "version": "3.1",
    "deload_rule": "manual_toggle",
    "deload_weight_multiplier": 0.5,
    "note": "80/20 program. Priority: climbing V12, longevity. Finger recovery ongoing. Right knee, left QL, right shoulder limitations accounted for.",
    "db_weight_convention": "working_weight for dumbbell exercises = total weight (both DBs combined). e.g. working_weight: 60 = 30 lb per hand."
  },

  "daily": ["finger_prehab_1", "finger_prehab_2"],

  "weekly": {
    "monday": ["climbing_warmup", "easy_bouldering", "post_stretch_climb"],
    "tuesday": ["lift_warmup", "lift_full_body", "post_stretch_lift"],
    "wednesday": ["climbing_warmup", "climbing_wed", "post_stretch_climb"],
    "thursday": ["mobility_recovery"],
    "friday": ["climbing_warmup", "easy_bouldering", "post_stretch_climb"],
    "saturday": ["climbing_warmup", "easy_bouldering", "post_stretch_climb"],
    "sunday": ["post_stretch_climb"]
  },

  "blocks": {
    "climbing_warmup": {
      "name": "Climbing Warmup",
      "type": "flow",
      "flow_label": "Climbing warmup",
      "flow_sub": "bird dog · copenhagen · dynamic mobility",
      "timer_routine": {
        "name": "Climbing Warmup",
        "description": "Dynamic warmup before climbing. ~5 min.",
        "sets": 1,
        "blocks": [
          {
            "type": "prepare",
            "label": "Ankle circles — right foot. Stand on left foot, draw big circles with right. Both directions",
            "duration": 6,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Ankle circles — right",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch to left foot",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Ankle circles — left",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Hip circles — hands on hips, big slow circles. Right direction first",
            "duration": 6
          },
          {
            "type": "work",
            "label": "Hip circles — right direction",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Reverse direction",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Hip circles — left direction",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Shoulder circles — backward. Right arm first",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Shoulder circles backward — right arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left arm",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Shoulder circles backward — left arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Shoulder circles — forward. Right arm first",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Shoulder circles forward — right arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left arm",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Shoulder circles forward — left arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Wrist circles — right arm out, draw big circles both directions",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Wrist circles — right",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left wrist",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Wrist circles — left",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Bird dog. Hands and knees. Extend right arm and left leg",
            "duration": 6,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Bird dog — right arm, left leg",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Switch. Left arm, right leg",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Bird dog — left arm, right leg",
            "duration": 20,
            "countdown_last": 20
          },
          {
            "type": "rest",
            "label": "Copenhagen plank. Top foot on chair. Right side first",
            "duration": 6,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Copenhagen — right side",
            "duration": 30,
            "countdown_last": 10
          },
          { "type": "rest", "label": "Switch to left side", "duration": 4 },
          {
            "type": "work",
            "label": "Copenhagen — left side",
            "duration": 30,
            "countdown_last": 10
          }
        ]
      },
      "exercises": [
        {
          "id": "cw_bd",
          "name": "Bird dog",
          "sets": 2,
          "reps": 10,
          "note": "per side"
        },
        {
          "id": "cw_cop",
          "name": "Copenhagen plank",
          "sets": 1,
          "duration": 30,
          "note": "per side"
        }
      ]
    },

    "lift_warmup": {
