            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Knee circles — hands on knees, slow circles both directions. Right leg first",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Knee circles — right",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left knee",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Knee circles — left",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Hip circles — hands on hips, big circles. Right direction first",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Hip circles — right direction",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Reverse direction",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Hip circles — left direction",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Hip hinges — feet hip width, hinge forward from hips, flat back",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Hip hinges",
            "duration": 20,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Thoracic rotation — hands behind head, rotate side to side slowly",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Thoracic rotation",
            "duration": 25,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Shoulder circles backward — right arm first",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Shoulder circles backward — right arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left arm",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Shoulder circles backward — left arm",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Arm swings — cross-body swings, right arm first",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Arm swings — right",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left arm",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Arm swings — left",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Wrist circles — right arm out, full circles both directions",
            "duration": 5
          },
          {
            "type": "work",
            "label": "Wrist circles — right",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Switch to left wrist",
            "duration": 3
          },
          {
            "type": "work",
            "label": "Wrist circles — left",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Finger extensions — spread fingers wide, hold, release",
            "duration": 4
          },
          {
            "type": "work",
            "label": "Finger extensions — both hands",
            "duration": 15,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Bodyweight squat flow. Slow squat down, pause at bottom, stand and hinge. Five reps",
            "duration": 6,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Squat to hinge flow",
            "duration": 30,
            "countdown_last": 10
          },
          {
            "type": "rest",
            "label": "Bird dog — right arm left leg",
            "duration": 5,
            "countdown_last": 3
          },
          {
            "type": "work",
            "label": "Bird dog — right arm, left leg",
            "duration": 20,
            "countdown_last": 20
          },
          { "type": "rest", "label": "Switch sides", "duration": 4 },
          {
            "type": "work",
            "label": "Bird dog — left arm, right leg",
            "duration": 20,
            "countdown_last": 20
          }
        ]
      },
      "exercises": [
        {
          "id": "lw1",
          "name": "Joint circles top to bottom",
          "sets": 1,
          "reps": 1,
          "note": "use timer"
        },
        { "id": "lw2", "name": "Bodyweight squat flow", "sets": 1, "reps": 5 }
      ]
    },

